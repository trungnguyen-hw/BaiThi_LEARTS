PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# Comma-separated list of allowed CORS origins
CLIENT_URLS=http://localhost:5173,https://YOUR-FRONTEND.vercel.app

# Seeds config (Only needed for initial migration/seed, not required in production)
SEED_ADMIN_USERNAME=example_admin
SEED_ADMIN_PASSWORD=change_me
SEED_ADMIN_FULL_NAME=Example Admin
SEED_ADMIN_EMAIL=admin@example.com
